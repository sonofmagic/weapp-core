{
  "name": "weapp-core",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.28.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/weapp-core.git"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "turbo run build --filter=@weapp-core/escape",
    "dev": "turbo run dev --parallel",
    "test": "vitest run --coverage.enabled",
    "test:dev": "vitest --coverage.enabled",
    "test:types": "pnpm --filter @weapp-core/escape test:types",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "release": "changeset",
    "publish-packages": "turbo run build lint --filter=@weapp-core/escape && npm run test && changeset version && changeset publish",
    "sync": "cnpm sync @weapp-core/escape @weapp-core/regex",
    "script:init": "monorepo init",
    "script:sync": "monorepo sync",
    "script:clean": "monorepo clean",
    "script:mirror": "monorepo mirror",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@icebreakers/changelog-github": "^1.0.2",
    "@icebreakers/commitlint-config": "^3.0.1",
    "@icebreakers/eslint-config": "^5.0.3",
    "@icebreakers/monorepo": "^4.0.10",
    "@icebreakers/stylelint-config": "^4.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/klaw": "^3.0.7",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "@types/set-value": "^4.0.3",
    "@vitest/coverage-v8": "~4.1.7",
    "@weapp-core/escape": "workspace:^",
    "@weapp-core/regex": "workspace:^",
    "ci-info": "^4.4.0",
    "cross-env": "^10.1.0",
    "defu": "^6.1.7",
    "es-toolkit": "^1.47.0",
    "eslint": "^10.4.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "get-value": "^4.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "micromatch": "^4.0.8",
    "miniprogram-api-typings": "^5.2.1",
    "only-allow": "^1.2.2",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "set-value": "^4.1.0",
    "stylelint": "^17.12.0",
    "ts-node": "^10.9.2",
    "tsd": "^0.33.0",
    "tsdown": "^0.22.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "turbo": "^2.9.15",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "~4.1.7",
    "yaml": "^2.9.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
